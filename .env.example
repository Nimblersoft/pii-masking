# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Service ---
PORT=8090

# If true, /mask requires a valid X-API-Key header. Default false (internal use).
REQUIRE_API_KEY=false

# --- Secrets (do NOT commit real values) ---
# Admin key for the /tokens surface. Auto-generated and logged once if unset.
PII_MASTER_KEY=

# Salt for placeholder-token hashing. Keep stable so the same PII value always
# maps to the same token across requests/restarts. Auto-generated (ephemeral)
# if unset, which breaks cross-restart token consistency.
PII_HASH_SALT=

# --- Infisical (optional secret backend) ---
# When project id + client credentials are set, entrypoint.sh fetches secrets
# (e.g. PII_MASTER_KEY) from Infisical at startup instead of reading them here.
INFISICAL_PROJECT_ID=
INFISICAL_API_URL=https://app.infisical.com
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=

# --- CLI (cli.py) ---
# Base URL the token CLI talks to. Defaults to http://localhost:8090.
PII_URL=http://localhost:8090
